rules_version = '2';

// Security rules for the ALEX POS app.
//
// Two parallel trust levels live here:
//   1. "Device" users  — anonymous Firebase auth, identified by their
//      own uid. They read/write data under the shop they joined, and
//      they own exactly one doc under /devices/{installId}.
//   2. "Super admins"  — listed explicitly in /admins/{uid}. They have
//      full read/write across /shops, /devices, and /admins so they
//      can manage the whole fleet from the in-app admin panel.
//
// Business-approval workflow:
//   - A device user can create a new business via /shops/{newId} with
//     `approvalStatus: pendingSystemAdmin`. Only super admins can
//     change that field, so the new business is locked out of POS
//     features until approved.
//   - A device user can submit a staff join request by writing
//     /shops/{shopId}/members/{auth.uid} with role `staff` and
//     `approvalStatus: pendingOwner`. Only the approved owner of the
//     shop (or a super admin) can change that doc's approval.
//
// IMPORTANT: the first admin must be created manually in the Firebase
// console (Authentication → add email/password user, then Firestore →
// create doc /admins/<that-uid> with any payload).

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isShopMember(shopId) {
      return isSignedIn()
          && exists(
              /databases/$(database)/documents/shops/$(shopId)/members/$(request.auth.uid)
          );
    }

    // Returns the shop doc's approval status, defaulting to "approved"
    // for legacy docs that predate the approval workflow.
    function shopApprovalStatus(shopId) {
      return get(/databases/$(database)/documents/shops/$(shopId))
          .data.get('approvalStatus', 'approved');
    }

    // Returns the member doc's approval status, defaulting to "approved"
    // so legacy member docs keep working.
    function memberApprovalStatus(shopId, uid) {
      return get(
              /databases/$(database)/documents/shops/$(shopId)/members/$(uid)
          ).data.get('approvalStatus', 'approved');
    }

    function memberRole(shopId, uid) {
      return get(
              /databases/$(database)/documents/shops/$(shopId)/members/$(uid)
          ).data.get('role', 'staff');
    }

    function isApprovedShopMember(shopId) {
      return isShopMember(shopId)
          && memberApprovalStatus(shopId, request.auth.uid) == 'approved'
          && shopApprovalStatus(shopId) == 'approved';
    }

    function isApprovedShopOwner(shopId) {
      return isShopMember(shopId)
          && memberRole(shopId, request.auth.uid) == 'owner'
          && memberApprovalStatus(shopId, request.auth.uid) == 'approved';
    }

    // Staff onboarding: submit or re-submit a join request to an
    // already system-approved shop.
    function isStaffJoinRequest(shopId, memberUid) {
      return isSignedIn()
          && request.auth.uid == memberUid
          && request.resource.data.role == 'staff'
          && request.resource.data.approvalStatus == 'pendingOwner'
          && shopApprovalStatus(shopId) == 'approved';
    }

    // Staff may re-open a rejected request without owner intervention.
    function isStaffResubmitAfterRejection(shopId, memberUid) {
      return isSignedIn()
          && request.auth.uid == memberUid
          && resource.data.get('approvalStatus', '') == 'rejected'
          && request.resource.data.role == 'staff'
          && request.resource.data.approvalStatus == 'pendingOwner'
          && shopApprovalStatus(shopId) == 'approved';
    }

    // Fields on /shops/{shopId} that only admins may change.
    function shopReservedFields() {
      return [
        'enabled',
        'licenseExpiresAt',
        'featureFlags',
        'pinForcedFlags',
        'maxProducts',
        'maxSalesPerDay',
        'notice',
        'approvalStatus',
        'approvedAt',
        'approvedBy',
        'rejectedAt',
        'rejectedBy',
        'rejectionReason',
        'ownerUid',
        'code',
      ];
    }

    // Fields on /shops/{shopId}/members/{uid} that a member cannot
    // change about themselves (they are set by the approver).
    function memberReservedFields() {
      return [
        'role',
        'approvalStatus',
        'approvedAt',
        'approvedBy',
        'rejectedAt',
        'rejectedBy',
        'rejectionReason',
      ];
    }

    // ---------- /admins ----------
    // Full read/write only for other admins. Non-admins cannot even
    // discover whether an admin allowlist exists.
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    // ---------- /devices ----------
    // A device (anonymous-auth uid) may read & upsert its own doc.
    // Admins can read / write every device doc.
    match /devices/{installId} {
      allow read: if isAdmin()
          || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if isAdmin()
          || (isSignedIn() && request.resource.data.ownerUid == request.auth.uid);
      allow update: if isAdmin()
          || (
            isSignedIn()
            && resource.data.ownerUid == request.auth.uid
            && request.resource.data.ownerUid == request.auth.uid
            // A device cannot raise its own expiry or clear its block.
            && !("blocked" in request.resource.data.diff(resource.data).affectedKeys())
            && !("expiresAt" in request.resource.data.diff(resource.data).affectedKeys())
            && !("featureOverrides" in request.resource.data.diff(resource.data).affectedKeys())
          );
      allow delete: if isAdmin();

      match /usageDaily/{day} {
        allow read: if isAdmin()
            || (isSignedIn()
                && get(/databases/$(database)/documents/devices/$(installId)).data.ownerUid
                    == request.auth.uid);
        allow write: if isAdmin()
            || (isSignedIn()
                && get(/databases/$(database)/documents/devices/$(installId)).data.ownerUid
                    == request.auth.uid);
      }

      // Admin-only audit trail of every change made to this device doc
      // via the admin panel. Writes are create-only (no updates, no
      // deletes) so the history is immutable.
      match /auditLog/{entryId} {
        allow read, create: if isAdmin();
        allow update, delete: if false;
      }
    }

    // ---------- /shops ----------
    match /shops/{shopId} {
      // Any signed-in user can read the shop doc so the staff onboarding
      // flow can search/browse businesses by name. Subcollections (sales,
      // members, etc.) stay tightly scoped below.
      allow read: if isSignedIn();

      // A new business is always created as `pendingSystemAdmin` by the
      // owner themselves. The system admin flips the status later.
      allow create: if isSignedIn()
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.approvalStatus == 'pendingSystemAdmin';

      // Admins may change anything. Members may only update
      // non-reserved fields (display name, settings, etc.).
      allow update: if isAdmin()
          || (isShopMember(shopId)
              && !(
                  request.resource.data.diff(resource.data).affectedKeys()
                      .hasAny(shopReservedFields())
              ));

      // Admins can always delete. The owner of a still-pending or
      // rejected shop can delete it themselves so they can resubmit.
      allow delete: if isAdmin()
          || (isSignedIn()
              && resource.data.ownerUid == request.auth.uid
              && resource.data.get('approvalStatus', 'approved') != 'approved');

      // ----- members subcollection (approval-aware) -----
      match /members/{memberUid} {
        // Read: admin, the member themselves (to learn their own
        // approval state), or any approved member of the shop (so the
        // owner can see staff requests).
        allow read: if isAdmin()
            || (isSignedIn() && request.auth.uid == memberUid)
            || isApprovedShopMember(shopId);

        // Create:
        //   * admin can create any member;
        //   * the shop owner (ownerUid on the shop doc) can create
        //     themselves as the approved `owner` member;
        //   * any signed-in user can submit themselves as a staff
        //     request (pendingOwner) for an existing shop.
        allow create: if isAdmin()
            || (isSignedIn()
                && request.auth.uid == memberUid
                && request.resource.data.role == 'owner'
                && request.resource.data.approvalStatus == 'approved'
                && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid
                    == request.auth.uid)
            || isStaffJoinRequest(shopId, memberUid);

        // Update:
        //   * admin can change anything;
        //   * an approved shop owner can change role/approvalStatus of
        //     other members in their shop;
        //   * a member can update their own non-reserved fields (e.g.
        //     change their displayName/phone) but not their role or
        //     approval state.
        allow update: if isAdmin()
            || isApprovedShopOwner(shopId)
            || isStaffResubmitAfterRejection(shopId, memberUid)
            || (isSignedIn()
                && request.auth.uid == memberUid
                && !(
                    request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(memberReservedFields())
                ));

        // Delete: admin, the user themselves (leave the shop), or an
        // approved owner (remove a staff member).
        allow delete: if isAdmin()
            || (isSignedIn() && request.auth.uid == memberUid)
            || isApprovedShopOwner(shopId);
      }

      // Admin-only audit trail. The wildcard subcollection rule below
      // explicitly excludes `auditLog` so members cannot read/write it.
      match /auditLog/{entryId} {
        allow read, create: if isAdmin();
        allow update, delete: if false;
      }

      // Subcollections (entities) — existing pattern: an APPROVED shop
      // member (or admin) reads / writes shop data. The wildcard
      // excludes the two collections handled by their own blocks
      // above (members, auditLog).
      match /{subcollection}/{docId} {
        allow read, write: if subcollection != 'members'
            && subcollection != 'auditLog'
            && (isAdmin() || isApprovedShopMember(shopId));
      }

      match /{subcollection}/{docId}/{rest=**} {
        allow read, write: if subcollection != 'members'
            && subcollection != 'auditLog'
            && (isAdmin() || isApprovedShopMember(shopId));
      }
    }

    // Fallback: deny anything not covered above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
